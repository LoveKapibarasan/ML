# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit real credentials.

# ── PostgreSQL (citrine OCPP backend) ──────────────────────────────────────────
DB_HOST=172.25.30.7
DB_PORT=5432
DB_NAME=citrine
DB_USER=citrine
DB_PASSWORD=

# ── ENTSO-E Transparency Platform ─────────────────────────────────────────────
# Get a free token at https://transparency.entsoe.eu/usrm/user/myAccountSettings
ENTSOE_TOKEN=

# ── Inference server (serve.py / serve.sh) ─────────────────────────────────────
SERVE_HOST=0.0.0.0
SERVE_PORT=8000
MAX_POWER_KW=11.0          # EV charger max power rating (kW)
WEATHER_LAT=52.52          # Site latitude  (default: Berlin)
WEATHER_LON=13.41          # Site longitude (default: Berlin)
# MODEL_PATH=models/best_model  # override if needed
